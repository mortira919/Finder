# Google Maps Places API Key
# Получить: https://console.cloud.google.com → APIs & Services → Places API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Город/регион для поиска (можно менять)
SEARCH_CITY=Алматы

# Категории бизнеса для поиска (через запятую)
SEARCH_CATEGORIES=ресторан,салон красоты,стоматология,фитнес клуб,автосервис,магазин,отель,аптека

# Максимум компаний за один запуск
MAX_RESULTS=100
